{
  "name": "Common: release tag format",
  "target": "tag",
  "enforcement": "active",
  "conditions": {
    "ref_name": {
      "include": [
        "refs/tags/*"
      ],
      "exclude": [
        "refs/tags/[0-9]",
        "refs/tags/[0-9][0-9]",
        "refs/tags/[0-9][0-9][0-9]",
        "refs/tags/[0-9][0-9][0-9][0-9]",
        "refs/tags/[0-9][0-9][0-9][0-9][0-9]",
        "refs/tags/[0-9][0-9][0-9][0-9][0-9][0-9]",
        "refs/tags/[0-9][0-9][0-9][0-9][0-9][0-9][0-9]",
        "refs/tags/[0-9][0-9][0-9][0-9][0-9][0-9][0-9][0-9]",
        "refs/tags/[0-9][0-9][0-9][0-9][0-9][0-9][0-9][0-9][0-9]"
      ]
    }
  },
  "rules": [
    {
      "type": "deletion"
    },
    {
      "type": "non_fast_forward"
    },
    {
      "type": "tag_name_pattern",
      "parameters": {
        "name": "Release tag format",
        "negate": false,
        "operator": "regex",
        "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)(-(alpha|beta)[0-9]+)?$"
      }
    }
  ]
}
